model User {
    id        String     @id @default(uuid())
    name      String     @db.VarChar(255)
    email     String     @unique
    password  String
    role      UserRole   @default(TENANT)
    status    UserStatus @default(ACTIVE)
    createdAt DateTime   @default(now())
    updatedAt DateTime   @updatedAt

    profile        Profile?
    

    @@map("user")
}
