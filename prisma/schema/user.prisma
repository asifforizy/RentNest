model User {
    id           String     @id @default(uuid())
    name         String     @db.VarChar(255)
    email        String     @unique
    password     String
    profilePhoto String?
    phone        String?    @db.VarChar(20)
    address      String?
    role         UserRole   @default(TENANT)
    status       UserStatus @default(ACTIVE)
    createdAt    DateTime   @default(now())
    updatedAt    DateTime   @updatedAt

    @@map("user")
}
